# Cloudflare Pages redirects (evaluated before the server worker).
# GitHub Pages ignores this file.
#
# NOTE: do NOT add a `/en /en/` rule here — Cloudflare strips the trailing
# slash before matching, so the rule also catches /en/ itself and the
# resulting self-redirect loop makes the EN homepage return 404.
#
# 1. Legacy /en/angebote/* URLs (old language-switcher targets and the moved
#    cafe page). The Cloudflare server build 404s these instead of serving
#    the Astro i18n fallback, so redirect explicitly to the EN routes.
/en/angebote/ /en/programs/ 301
/en/angebote /en/programs/ 301
/en/angebote/mini-turnen/ /en/programs/mini-sports/ 301
/en/angebote/mini-turnen /en/programs/mini-sports/ 301
/en/angebote/mini-garten/ /en/programs/mini-garden/ 301
/en/angebote/mini-garten /en/programs/mini-garden/ 301
/en/angebote/mini-projekte/ /en/programs/mini-projects/ 301
/en/angebote/mini-projekte /en/programs/mini-projects/ 301
/en/angebote/mini-projekte/mini-restaurant/ /en/programs/mini-projects/mini-restaurant/ 301
/en/angebote/mini-projekte/mini-restaurant /en/programs/mini-projects/mini-restaurant/ 301
/en/angebote/mini-abenteuercamp/ /en/programs/mini-adventure-camp/ 301
/en/angebote/mini-abenteuercamp /en/programs/mini-adventure-camp/ 301
/en/angebote/mini-museum/ /en/programs/mini-museum/ 301
/en/angebote/mini-museum /en/programs/mini-museum/ 301
/en/angebote/tagesschule/ /en/programs/day-school/ 301
/en/angebote/tagesschule /en/programs/day-school/ 301
