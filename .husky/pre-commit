# Check for secrets before committing
# This prevents accidental API key leaks
python3 scripts/check_secrets.py --staged-only

# Second secrets scanner: gitleaks (covers patterns check_secrets.py misses)
if ! command -v gitleaks >/dev/null 2>&1; then
    echo "gitleaks not found; brew install gitleaks" >&2
    exit 1
fi
gitleaks protect --staged --redact --no-banner

# Run TypeScript type checking before committing
# This prevents commits with TypeScript errors from being deployed
npm run build
