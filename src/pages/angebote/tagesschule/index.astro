---
import Base from '@layouts/Base.astro';
import TagesschulePage from '@components/programs/TagesschulePage.astro';
import { getEntry } from 'astro:content';
import { getLangFromUrl, useTranslatedPath } from '@i18n/utils';

const lang = getLangFromUrl(Astro.url);
const translatePath = useTranslatedPath(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Get CMS content
const pageEntry = await getEntry('pages', 'tagesschule');
const page = pageEntry?.data;

// Get site images from CMS
const siteImagesEntry = await getEntry('settings', 'images');
const siteImages = siteImagesEntry?.data;
const heroImage = siteImages?.programmeHeroes?.tagesschule
  ? base + siteImages.programmeHeroes.tagesschule
  : base + "/images/programs/tagesschule-hero.webp";

// SEO-09: keyword title is intentionally NOT CMS-overridable (decoupled from hero.titel per D6)
const seoTitle = lang === 'de' ? 'Tagesschule – Schule für Kinder im Spektrum' : 'Day School – For Children on the Spectrum';
const pageDescription = lang === 'de'
  ? 'Strukturiertes Tagesschulprogramm mit individueller Förderung für Kinder im Autismus Spektrum in Zürich.'
  : 'Structured day school program with individual support for children on the autism spectrum in Zurich.';
---

<Base title={seoTitle} description={pageDescription}>
  <TagesschulePage content={page} lang={lang} translatePath={translatePath} heroImage={heroImage} />
</Base>
