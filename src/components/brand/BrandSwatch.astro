---
/**
 * BrandSwatch — click-to-copy color chip.
 *
 * Renders a real <button> (keyboard accessible) carrying data-copy={hex}.
 * The page (or any global handler) should attach a click listener that
 * reads `data-copy` and writes to navigator.clipboard, optionally showing
 * a toast.
 */
interface Props {
  name: string;
  hex: string;
  use?: string;
  class?: string;
}

const { name, hex, use, class: className } = Astro.props;
const isWhiteish = hex.toUpperCase() === '#FFFFFF' || hex.toUpperCase() === '#FFFBF7';
---

<button
  type="button"
  class:list={['brand-swatch', className]}
  data-copy={hex}
  aria-label={`Hex-Wert ${hex} kopieren`}
>
  <span
    class:list={['brand-swatch__fill', { 'brand-swatch__fill--whiteish': isWhiteish }]}
    style={`background:${hex}`}
  ></span>
  <span class="brand-swatch__meta">
    <span class="brand-swatch__name">{name}</span>
    <span class="brand-swatch__hex">{hex}</span>
    {use && <span class="brand-swatch__use">{use}</span>}
  </span>
</button>

<style>
  .brand-swatch {
    appearance: none;
    border: 1px solid rgba(45, 42, 50, 0.06);
    background: var(--evolea-white);
    border-radius: 18px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-align: left;
    cursor: pointer;
    padding: 0;
    width: 100%;
    transition: transform 140ms cubic-bezier(0.22, 0.61, 0.36, 1), box-shadow 140ms;
  }
  .brand-swatch:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-soft);
  }
  .brand-swatch:focus-visible {
    outline: 2px solid var(--evolea-magenta);
    outline-offset: 2px;
  }

  .brand-swatch__fill {
    display: block;
    aspect-ratio: 4 / 3;
  }
  .brand-swatch__fill--whiteish {
    box-shadow: inset 0 0 0 1px rgba(45, 42, 50, 0.12);
  }

  .brand-swatch__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 12px 14px;
  }
  .brand-swatch__name {
    font-weight: 600;
    font-size: 14px;
    color: var(--evolea-deep-purple);
  }
  .brand-swatch__hex {
    font-family: 'JetBrains Mono', ui-monospace, Menlo, monospace;
    font-size: 11.5px;
    color: var(--evolea-text-light);
    letter-spacing: 0.04em;
  }
  .brand-swatch:hover .brand-swatch__hex {
    color: var(--evolea-magenta);
  }
  .brand-swatch__use {
    font-size: 11px;
    color: #BDB4A2;
  }
</style>
