<script is:inline define:vars={{ copiedSuffix: copy.toast.copied[lang] }}>
  // Hex copy + toast handler. Listens globally for [data-copy] activations.
  const toast = document.getElementById('brand-toast');
  let toastTimer;
  function showToast(msg) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('brand-toast--show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('brand-toast--show'), 1800);
  }
  document.addEventListener('click', (e) => {
    const target = /** @type {HTMLElement | null} */ (e.target);
    if (!target) return;
    const cp = target.closest('[data-copy]');
    if (cp instanceof HTMLElement) {
      const value = cp.dataset.copy ?? '';
      if (navigator.clipboard) {
        navigator.clipboard.writeText(value).catch(() => {});
      }
      showToast(`${value}${copiedSuffix}`);
    }
  });
</script>

