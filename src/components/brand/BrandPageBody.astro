      { label: 'ZIP', size: isDE ? 'auf Anfrage' : 'on request', url: requestKitMailto, primary: true, isFile: false },
    ],
  },
  {
    id: 'fonts',
    name: isDE ? 'Schriften · Fredoka + Poppins' : 'Fonts · Fredoka + Poppins',
    desc: isDE ? 'Beide Schriften unter SIL Open Font License — wir verlinken die offiziellen Quellen.' : 'Both under SIL Open Font License — we link the official sources.',
    tag: 'Type',
    thumb: { fontPreview: true as const, mode: 'gradient' as const },
    formats: [
      { label: 'Fredoka ↗', size: 'Google Fonts', url: 'https://fonts.google.com/specimen/Fredoka', primary: true, isFile: false, external: true },
      { label: 'Poppins ↗', size: 'Google Fonts', url: 'https://fonts.google.com/specimen/Poppins', primary: false, isFile: false, external: true },
    ],
  },
];

const WATERCOLORS = [
  { src: `${base}/images/blog/im-spektrum.webp`, name: isDE ? 'Im Spektrum' : 'In the spectrum' },
  { src: `${base}/images/hero/spenden-hero.png`, name: isDE ? 'Spenden · Schloss' : 'Donate · castle' },
  { src: `${base}/images/hero/angebote-hero.png`, name: isDE ? 'Angebote' : 'Programs' },
];

const TEAM = [
  { src: `${base}/images/team/alexandra-aleksic.jpg`, name: 'Alexandra Aleksic' },
  { src: `${base}/images/team/annemarie-elias.png`, name: 'Annemarie Elias' },
  { src: `${base}/images/team/christoph-jenny.png`, name: 'Christoph Jenny' },
  { src: `${base}/images/team/gianna-spiess.png`, name: 'Gianna Spiess' },
];
---

<div class="brand-page">
    <!-- ===================== HERO ====================================== -->
    <header id="top" class="brand-hero">
      <div class="brand-hero__canvas" aria-hidden="true">
        <div class="brand-blob brand-blob--b1"></div>
        <div class="brand-blob brand-blob--b2"></div>
        <div class="brand-blob brand-blob--b3"></div>
      </div>

      <div class="brand-hero__grid">
        <div class="brand-hero__copy">
          <span class="brand-hero__eyebrow">
            <BrandStripe variant="prism" height="2px" />
            <span>{t('hero', 'eyebrow')}</span>
          </span>
          <h1 class="brand-hero__title">
            <span>{t('hero', 'title1')}</span><br />
            <span class="brand-hero__title-accent">{t('hero', 'title2')}</span>
          </h1>
          <p class="brand-hero__lede">{t('hero', 'lede')}</p>
          <div class="brand-hero__actions">
            <BrandButton variant="donate" href={donatePath}>
              <span>{t('hero', 'ctaDonate')}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </BrandButton>
            <BrandButton variant="primary" href="#downloads">
              <span>{t('hero', 'ctaPrimary')}</span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </BrandButton>
            <BrandButton variant="ghost" href="#voice">{t('hero', 'ctaSecondary')}</BrandButton>
          </div>
        </div>

        <div class="brand-hero__art" aria-hidden="true">
          <div class="brand-frame brand-frame--f1">
            <img src={`${base}/images/blog/im-spektrum.webp`} alt="" loading="lazy" />
          </div>
          <div class="brand-frame brand-frame--f2">
            <img src={`${base}/images/hero/spenden-hero.png`} alt="" loading="lazy" />
          </div>
          <div class="brand-frame brand-frame--f3">
            <img src={`${base}/images/team/gianna-spiess.png`} alt="" loading="lazy" />
          </div>
          <div class="brand-fly brand-fly--a"><Butterfly variant="spectrum" size="md" /></div>
          <div class="brand-fly brand-fly--b"><Butterfly variant="spectrum" size="sm" /></div>
        </div>
      </div>
    </header>

    <!-- ===================== PHILOSOPHY ================================ -->
    <section id="philosophie" class="brand-sect brand-philosophy">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('phil', 'eyebrow')}</span>
            <h2>{t('phil', 'titleA')}<em>{t('phil', 'titleB')}</em>{t('phil', 'titleC')}</h2>
          </div>
          <p>{t('phil', 'lede')}</p>
        </div>

        <div class="brand-pillars">
          <article class="brand-pillar">
            <div class="brand-pillar__num">01 / Warm</div>
            <h3>{t('phil', 'p1Title')}</h3>
            <p>{t('phil', 'p1Body')}</p>
          </article>
          <article class="brand-pillar brand-pillar--feat">
            <div class="brand-pillar__num">{isDE ? '02 / Spektrum' : '02 / Spectrum'}</div>
            <h3>{t('phil', 'p2Title')}</h3>
            <p>{t('phil', 'p2Body')}</p>
          </article>
          <article class="brand-pillar">
            <div class="brand-pillar__num">{isDE ? '03 / Schmetterling' : '03 / Butterfly'}</div>
            <h3>{t('phil', 'p3Title')}</h3>
            <p>{t('phil', 'p3Body')}</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ===================== LOGO + DOWNLOADS ========================== -->
    <section id="logo" class="brand-sect">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('logo', 'eyebrow')}</span>
            <h2>{t('logo', 'title')}</h2>
          </div>
          <p>{t('logo', 'lede')}</p>
        </div>

        <div class="brand-logo-board">
          <div>
            <div class="brand-logo-stage">
              <img src={`${base}/images/logo/evolea-logo-new.png`} alt="EVOLEA Logo" loading="lazy" />
            </div>
            <div class="brand-logo-label">
              <span class="brand-logo-label__name">{t('logo', 'creamLabel')}</span>
              <span>{t('logo', 'creamNote')}</span>
            </div>
          </div>
          <div>
            <div class="brand-logo-stage brand-logo-stage--dark">
              <img src={`${base}/images/logo/evolea-logo-new.png`} alt="EVOLEA Logo on dark" loading="lazy" />
            </div>
            <div class="brand-logo-label">
              <span class="brand-logo-label__name">{t('logo', 'darkLabel')}</span>
              <span>{t('logo', 'darkNote')}</span>
            </div>
          </div>
          <div>
            <div class="brand-logo-stage brand-logo-stage--prism">
              <svg viewBox="0 0 220 100" aria-hidden="true">
                <text x="110" y="68" text-anchor="middle" fill="#fff" font-family="Fredoka" font-weight="700" font-size="58" letter-spacing="2" style="filter: drop-shadow(0 3px 8px rgba(0,0,0,.18))">EVOLEA</text>
              </svg>
            </div>
            <div class="brand-logo-label">
              <span class="brand-logo-label__name">{t('logo', 'prismLabel')}</span>
              <span>{t('logo', 'prismNote')}</span>
            </div>
          </div>
        </div>

        <!-- DOWNLOADS -->
        <div id="downloads" class="brand-downloads">
          <div class="brand-sect-head" style="margin-top:80px">
            <div>
              <span class="brand-eyebrow-mini">{t('dl', 'eyebrow')}</span>
              <h2>{t('dl', 'titleA')}<em>{t('dl', 'titleB')}</em>{t('dl', 'titleC')}</h2>
            </div>
            <p>{t('dl', 'lede')}</p>
          </div>

          <div class="brand-dl-grid">
            {DOWNLOADS.map((d) => (
              <article class="brand-dl-card" data-id={d.id}>
                <div class:list={['brand-dl-thumb', ...d.thumb.mode.split(' '), { 'brand-dl-thumb--has-fontpreview': 'fontPreview' in d.thumb && d.thumb.fontPreview, 'brand-dl-thumb--has-teampack': 'teamPack' in d.thumb && d.thumb.teamPack }]}>
                  {d.tag && <span class:list={['brand-dl-tag', { 'brand-dl-tag--dark': d.thumb.mode.includes('dark') || d.thumb.mode.includes('prism') }]}>{d.tag}</span>}
                  {'butterfly' in d.thumb ? (
                    <Butterfly variant={d.thumb.butterfly} size="lg" />
                  ) : 'fontPreview' in d.thumb && d.thumb.fontPreview ? (
                    <div class="brand-dl-fontpreview">
                      <div class="brand-dl-fontpreview__aa">Aa</div>
                      <div class="brand-dl-fontpreview__cap">Fredoka + Poppins</div>
                    </div>
                  ) : 'teamPack' in d.thumb && d.thumb.teamPack ? (
                    <div class="brand-dl-teampack">
                      {TEAM.map((p) => <div style={`background-image: url('${p.src}'); background-size: cover; background-position: center;`} aria-hidden="true"></div>)}
                    </div>
                  ) : 'src' in d.thumb && d.thumb.src ? (
                    <img src={d.thumb.src} alt={d.name} loading="lazy" />
                  ) : null}
                </div>
                <div class="brand-dl-meta">
                  <div class="brand-dl-info">
                    <h3 class="brand-dl-name">{d.name}</h3>
                    <p class="brand-dl-desc">{d.desc}</p>
                  </div>
                  <div class="brand-dl-btns">
                    {d.formats.map((f) => (
                      <a
                        class:list={['brand-dl-btn', { 'brand-dl-btn--primary': f.primary }]}
                        href={f.url}
                        download={f.isFile ? '' : undefined}
                        rel={'external' in f && f.external ? 'noopener noreferrer' : undefined}
                        target={'external' in f && f.external ? '_blank' : undefined}
                      >
                        {f.isFile ? (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                        ) : (
                          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        )}
                        <span>{f.label}</span><span style="opacity:.6;font-weight:500">· {f.size}</span>
                      </a>
                    ))}
                  </div>
                </div>
              </article>
            ))}
          </div>

          <!-- Mega request bar -->
          <div class="brand-megadown">
            <div class="brand-megadown__copy">
              <h3>{t('dl', 'megaTitle')}</h3>
              <p>{t('dl', 'megaBody')}</p>
            </div>
            <BrandButton variant="primary" href={requestKitMailto}>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <span>{t('dl', 'requestKit')}</span>
            </BrandButton>
          </div>
        </div>
      </div>
    </section>

    <!-- ===================== FARBEN ==================================== -->
    <section id="farben" class="brand-sect brand-sect--white">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('col', 'eyebrow')}</span>
            <h2>{t('col', 'title')}</h2>
          </div>
          <p>{t('col', 'lede')}</p>
        </div>

        <h4 class="brand-pal-heading">{t('col', 'primary')}</h4>
        <div class="brand-palette brand-palette--prim">
          {PRIMARY.map((s) => <BrandSwatch name={s.name} hex={s.hex} use={s.use} />)}
        </div>

        <h4 class="brand-pal-heading">{t('col', 'spectrum')}</h4>
        <div class="brand-palette brand-palette--spec">
          {SPECTRUM.map((s) => <BrandSwatch name={s.name} hex={s.hex} />)}
        </div>

        <h4 class="brand-pal-heading">{t('col', 'neutral')}</h4>
        <div class="brand-palette brand-palette--neut">
          {NEUTRAL.map((s) => <BrandSwatch name={s.name} hex={s.hex} use={s.use} />)}
        </div>
      </div>
    </section>

    <!-- ===================== GRADIENTS ================================= -->
    <section id="gradients" class="brand-sect">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('grad', 'eyebrow')}</span>
            <h2>{t('grad', 'title')}</h2>
          </div>
          <p>{t('grad', 'lede')}</p>
        </div>
        <div class="brand-grad-grid">
          {GRADIENTS.map((g) => (
            <article class="brand-gradcard">
              <div class="brand-gradcard__strip" style={`background:${g.css};`}></div>
              <div class="brand-gradcard__body">
                <h4>{g.name}</h4>
                <p>{g.use}</p>
                <code>{g.css}</code>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== TYPOGRAFIE ================================ -->
    <section id="typo" class="brand-sect brand-sect--white">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('typo', 'eyebrow')}</span>
            <h2>{t('typo', 'title')}</h2>
          </div>
          <p>{t('typo', 'lede')}</p>
        </div>

        <div class="brand-typo-grid">
          <article class="brand-typo-card">
            <div class="brand-typo-card__label">
              <span>Fredoka · Display</span><span>Aa</span>
            </div>
            <p class="brand-typo-card__display">
              Aa <span class="brand-typo-card__ax">Bb</span> Cc Üü
            </p>
            <p class="brand-typo-card__glyphs">ABCDEFGHIJKLMNOPQRSTUVWXYZ &nbsp; abcdefghijklmnopqrstuvwxyz &nbsp; 0123456789 &nbsp; ÄÖÜß</p>
            <div class="brand-typo-card__specifics">
              <div><b>{t('typo', 'weights')}</b>SemiBold 600 · Bold 700</div>
              <div><b>{t('typo', 'usage')}</b>{t('typo', 'fredokaUse')}</div>
              <div><b>{t('typo', 'minSize')}</b>20px Display</div>
            </div>
          </article>
          <article class="brand-typo-card">
            <div class="brand-typo-card__label">
              <span>Poppins · Body</span><span>Aa</span>
            </div>
            <p class="brand-typo-card__body-spec">{t('typo', 'sampleBody')}</p>
            <p class="brand-typo-card__glyphs brand-typo-card__glyphs--sans">ABCDEFGHIJKLMNOPQRSTUVWXYZ &nbsp; abcdefghijklmnopqrstuvwxyz &nbsp; 0123456789 &nbsp; ÄÖÜß</p>
            <div class="brand-typo-card__specifics">
              <div><b>{t('typo', 'weights')}</b>Regular 400 · Medium 500 · SemiBold 600</div>
              <div><b>{t('typo', 'usage')}</b>{t('typo', 'poppinsUse')}</div>
              <div><b>{t('typo', 'lineHeight')}</b>{t('typo', 'poppinsLine')}</div>
            </div>
          </article>
        </div>

        <div class="brand-scale">
          <div class="brand-scale__row"><span class="brand-scale__role">{t('typo', 'scaleDisplay')}</span><span class="brand-scale__size">clamp(44, 7vw, 80)</span><span class="brand-scale__demo" style="font-size:32px; line-height:1;">{t('typo', 'scaleDisplayDemo')}</span></div>
          <div class="brand-scale__row"><span class="brand-scale__role">H1</span><span class="brand-scale__size">clamp(32, 5vw, 56)</span><span class="brand-scale__demo" style="font-size:26px;">{t('typo', 'scaleH1Demo')}</span></div>
          <div class="brand-scale__row"><span class="brand-scale__role">H2</span><span class="brand-scale__size">clamp(28, 4vw, 44)</span><span class="brand-scale__demo" style="font-size:22px;">{t('typo', 'scaleH2Demo')}</span></div>
          <div class="brand-scale__row"><span class="brand-scale__role">H3</span><span class="brand-scale__size">28 / 1.25</span><span class="brand-scale__demo" style="font-size:18px;">{t('typo', 'scaleH3Demo')}</span></div>
          <div class="brand-scale__row"><span class="brand-scale__role">Body</span><span class="brand-scale__size">16 / 1.65</span><span class="brand-scale__demo brand-scale__demo--sans">{t('typo', 'scaleBodyDemo')}</span></div>
          <div class="brand-scale__row"><span class="brand-scale__role">Eyebrow</span><span class="brand-scale__size">14 / .16em ↔</span><span class="brand-scale__demo brand-scale__demo--eyebrow">{t('typo', 'scaleEyebrowDemo')}</span></div>
        </div>
      </div>
    </section>

    <!-- ===================== BILDWELT ================================== -->
    <section id="bildwelt" class="brand-sect">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('img', 'eyebrow')}</span>
            <h2>{t('img', 'titleA')}<em>{t('img', 'titleB')}</em>{t('img', 'titleC')}</h2>
          </div>
          <p>{t('img', 'lede')}</p>
        </div>

        <h4 class="brand-imagery-heading">{t('img', 'water')}</h4>
        <div class="brand-img-grid">
          {WATERCOLORS.map((w) => (
            <article class="brand-img-tile">
              <img src={w.src} alt={w.name} loading="lazy" />
              <div class="brand-img-tile__cap">
                <span>{w.name}</span>
                <a href={w.src} download class="brand-img-tile__dl">↓ {isDE ? 'Bild' : 'image'}</a>
              </div>
            </article>
          ))}
        </div>

        <h4 class="brand-imagery-heading" style="margin-top: 32px">{t('img', 'team')}</h4>
        <div class="brand-team-grid">
          {TEAM.map((p) => (
            <article class="brand-team-card">
              <div class="brand-team-card__photo">
                <img src={p.src} alt={p.name} loading="lazy" />
              </div>
              <div class="brand-team-card__meta">
                <span class="brand-team-card__name">{p.name}</span>
                <a href={p.src} download class="brand-team-card__dl">↓ {isDE ? 'Foto' : 'photo'}</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===================== COMPONENTS ================================ -->
    <section id="components" class="brand-sect brand-sect--white">
      <div class="brand-wrap">
        <div class="brand-sect-head">
          <div>
            <span class="brand-eyebrow-mini">{t('comp', 'eyebrow')}</span>
            <h2>{t('comp', 'title')}</h2>
          </div>
          <p>{t('comp', 'lede')}</p>
        </div>

        <div class="brand-comp-grid">
          <article class="brand-comp-card">
            <h4>{t('comp', 'btnHeading')}</h4>
            <div class="brand-comp-row">
              <BrandButton variant="primary">{t('comp', 'btnPrimary')}</BrandButton>
              <BrandButton variant="ghost">{t('comp', 'btnGhost')}</BrandButton>
              <BrandButton variant="donate">
                <span>{t('comp', 'btnDonate')}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </BrandButton>
              <BrandButton variant="outline">{t('comp', 'btnOutline')}</BrandButton>
            </div>
            <p class="brand-comp-card__note">{t('comp', 'btnNote')}</p>
          </article>

          <article class="brand-comp-card">
            <h4>{t('comp', 'chipsHeading')}</h4>
            <div class="brand-comp-row">
              <span class="brand-chip brand-chip--magenta">
                <Butterfly variant="spectrum" size="xs" />
                {t('comp', 'chipInclusive')}
              </span>
              <span class="brand-chip brand-chip--green">{t('comp', 'chipEvidence')}</span>
              <span class="brand-chip brand-chip--gold">{t('comp', 'chipFamily')}</span>
              <span class="brand-chip brand-chip--purple">{t('comp', 'chipParticipatory')}</span>
            </div>
          </article>

          <article class="brand-comp-card">
            <h4>{t('comp', 'cardHeading')}</h4>
            <div class="brand-story-card">
              <div class="brand-story-card__img" style={`background-image: url('${base}/images/blog/im-spektrum.webp')`}></div>
              <div class="brand-story-card__body">
                <span class="brand-story-card__eyebrow">{t('comp', 'cardEyebrow')}</span>
                <h4>{t('comp', 'cardTitle')}</h4>
                <p>{t('comp', 'cardBody')}</p>
              </div>
            </div>
          </article>

          <article class="brand-comp-card">
            <h4>{t('comp', 'ctaHeading')}</h4>
            <div class="brand-cta-block">
              <span class="brand-cta-block__eyebrow">{t('comp', 'ctaEyebrow')}</span>
              <h4>{t('comp', 'ctaTitle')}</h4>
              <p>{t('comp', 'ctaBody')}</p>
              <BrandButton variant="donate" href={donatePath}>
                <span>{t('comp', 'btnDonate')}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </BrandButton>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- ===================== VOICE ===================================== -->
    <section id="voice" class="brand-sect">
      <div class="brand-wrap">
        <div class="brand-voice-box">
          <p class="brand-voice-box__quote">
            <span>{t('voice', 'qA')}</span>
            <span class="brand-voice-box__accent">{t('voice', 'qB')}</span>
            <span>{t('voice', 'qC')}</span>
          </p>
          <div class="brand-voice-cols">
            <div>
              <h5>{t('voice', 'tone')}</h5>
              <ul>
                <li>{t('voice', 't1')}</li>
                <li>{t('voice', 't2')}</li>
                <li>{t('voice', 't3')}</li>
                <li>{t('voice', 't4')}</li>
              </ul>
            </div>
            <div>
              <h5>{t('voice', 'do')}</h5>
              <ul>
                <li>{t('voice', 'do1')}</li>
                <li>{t('voice', 'do2')}</li>
                <li>{t('voice', 'do3')}</li>
              </ul>
            </div>
