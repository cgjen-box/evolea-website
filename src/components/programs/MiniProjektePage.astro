---
import FloatingShapes from '@components/FloatingShapes.astro';
import Icon from '@components/Icon.astro';
import EditLink from '@components/EditLink.astro';
import JsonLd from '@components/JsonLd.astro';
import { breadcrumbSchema, serviceSchema } from '@/lib/seo';

const { content, lang, translatePath, heroImage } = Astro.props;

const page = content;

// Helper to get bilingual text
const getText = (obj: { de?: string; en?: string } | undefined, fallback: string = '') => {
  if (!obj) return fallback;
  return lang === 'de' ? (obj.de || fallback) : (obj.en || obj.de || fallback);
};

// Page content with fallbacks
const hero = page?.hero || {};
const infoKarten = page?.infoKarten || [];
const fuerWen = page?.fuerWen || {};
const besonderheiten = page?.besonderheiten || {};
const projekte = page?.projekte || {};
const praktischeInfos = page?.praktischeInfos || {};

// CMS links starting with '/' go through translatePath; '#' anchors stay as-is
const heroButtonLink = hero.buttonLink || '#projekte';
const heroButtonHref = heroButtonLink.startsWith('/') ? translatePath(heroButtonLink) : heroButtonLink;

// Color mappings for projects
const statusColors: Record<string, string> = {
  magenta: 'bg-evolea-magenta/20 text-evolea-magenta',
  green: 'bg-evolea-mint/20 text-evolea-green',
  orange: 'bg-evolea-orange/20 text-evolea-orange'
};
const borderColors: Record<string, string> = {
  orange: 'border-evolea-orange',
  purple: 'border-evolea-purple',
  green: 'border-evolea-green'
};
const fromColors: Record<string, string> = {
  orange: 'from-evolea-orange/10',
  purple: 'from-evolea-purple/10',
  green: 'from-evolea-green/10'
};
const textColors: Record<string, string> = {
  orange: 'text-evolea-orange',
  purple: 'text-evolea-purple',
  green: 'text-evolea-green'
};

// SEO-06: BreadcrumbList items mirror the visible breadcrumb nav below exactly.
const pageTitle = hero.titel || 'Mini Projekte';
const breadcrumbItems = [
  { label: lang === 'de' ? 'Startseite' : 'Home', href: translatePath('/') },
  { label: lang === 'de' ? 'Angebote' : 'Programs', href: translatePath('/angebote/') },
  { label: pageTitle },
];

// SEO-07: Service schema. Canonical URL = slash-normalized pathname against Astro.site.
const canonicalPath = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
const canonicalUrl = new URL(canonicalPath, Astro.site).href;
const serviceDescription = getText(hero.untertitel, lang === 'de' ? 'Stark im Miteinander, spielerisch fürs Leben lernen' : 'Strong together, learning playfully for life');
---

<!-- Hero Section -->
<section class="relative py-20 md:py-28 bg-gradient-to-br from-evolea-orange/10 to-evolea-cream overflow-hidden">
  <FloatingShapes variant="minimal" />
  <div class="container mx-auto max-w-6xl px-4 relative z-10">
    <nav class="mb-8 text-sm text-evolea-text-light">
      <a href={translatePath('/')} class="hover:text-evolea-purple transition-colors">{lang === 'de' ? 'Startseite' : 'Home'}</a>
      <span class="mx-2">/</span>
      <a href={translatePath('/angebote/')} class="hover:text-evolea-purple transition-colors">{lang === 'de' ? 'Angebote' : 'Programs'}</a>
      <span class="mx-2">/</span>
      <span class="text-evolea-purple font-medium">{hero.titel || 'Mini Projekte'}</span>
    </nav>
    <JsonLd schema={breadcrumbSchema(breadcrumbItems, Astro.site)} />
    <JsonLd schema={serviceSchema({ name: pageTitle, description: serviceDescription, url: canonicalUrl, lang, minAge: 5, maxAge: 8 })} />

    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <div class="inline-flex items-center gap-2 bg-evolea-orange/20 text-evolea-orange px-4 py-2 rounded-full text-sm font-medium mb-6">
          <Icon name="palette" size="sm" />
          <span>{getText(hero.badge, lang === 'de' ? 'Social Skills Gruppe' : 'Social Skills Group')}</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-display font-bold text-evolea-purple mb-6 leading-tight">
          {hero.titel || 'Mini Projekte'}
        </h1>
        <p class="text-xl md:text-2xl text-evolea-text-light mb-4 leading-relaxed">
          {getText(hero.untertitel, lang === 'de' ? 'Stark im Miteinander, spielerisch fürs Leben lernen' : 'Strong together, learning playfully for life')}
        </p>
        <p class="text-lg text-evolea-text-light mb-8">
          {getText(hero.beschreibung, lang === 'de' ? 'Geschützte Social Skills Gruppen für autistische Kinder ausserhalb der Schule – mit klarer Struktur und sichtbaren Erfolgen.' : 'Protected social skills groups for autistic children outside of school – with clear structure and visible successes.')}
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={heroButtonHref} class="btn-primary">
            {getText(hero.buttonText, lang === 'de' ? 'Aktuelle Projekte' : 'Current Projects')}
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
      <div class="relative">
        <img
          src={heroImage}
          alt={getText(hero.untertitel, lang === 'de' ? 'Kinder bei kreativen Projekten' : 'Children working on creative projects')}
          class="rounded-evolea-lg shadow-elevated w-full object-cover aspect-card"
        />
        <div class="absolute -bottom-4 -right-4 bg-white rounded-evolea p-4 shadow-card">
          <div class="text-3xl font-display font-bold text-evolea-orange">{hero.alter || '5-8'}</div>
          <div class="text-sm text-evolea-text-light">{lang === 'de' ? 'Jahre' : 'Years'}</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Key Info Cards -->
<section class="py-16 bg-white">
  <div class="container mx-auto max-w-6xl px-4">
    <div class="grid md:grid-cols-4 gap-6">
      {infoKarten.length > 0 ? (
        infoKarten.map((karte: any) => (
          <div class="bg-evolea-cream rounded-evolea-lg p-6 text-center">
            <div class="flex justify-center mb-3"><Icon name={karte.icon || 'sparkle'} size="lg" /></div>
            <div class="font-display font-bold text-evolea-purple text-lg">{getText(karte.label, '')}</div>
            <div class="text-evolea-text-light">{getText(karte.wert, '')}</div>
          </div>
        ))
      ) : (
        <>
          <div class="bg-evolea-cream rounded-evolea-lg p-6 text-center">
            <div class="flex justify-center mb-3"><Icon name="sparkle" size="lg" /></div>
            <div class="font-display font-bold text-evolea-purple text-lg">{lang === 'de' ? 'Alter' : 'Age'}</div>
            <div class="text-evolea-text-light">{lang === 'de' ? '5-8 Jahre' : '5-8 years'}</div>
          </div>
          <div class="bg-evolea-cream rounded-evolea-lg p-6 text-center">
            <div class="flex justify-center mb-3"><Icon name="clipboard" size="lg" /></div>
            <div class="font-display font-bold text-evolea-purple text-lg">{lang === 'de' ? 'Wann' : 'When'}</div>
            <div class="text-evolea-text-light">{lang === 'de' ? 'Samstag, alle 2 Wochen' : 'Saturday, every 2 weeks'}</div>
          </div>
          <div class="bg-evolea-cream rounded-evolea-lg p-6 text-center">
            <div class="flex justify-center mb-3"><Icon name="chart" size="lg" /></div>
            <div class="font-display font-bold text-evolea-purple text-lg">{lang === 'de' ? 'Dauer' : 'Duration'}</div>
            <div class="text-evolea-text-light">{lang === 'de' ? '3 Stunden / Halbtag' : '3 hours / half day'}</div>
          </div>
          <div class="bg-evolea-cream rounded-evolea-lg p-6 text-center">
            <div class="flex justify-center mb-3"><Icon name="diamond" size="lg" /></div>
            <div class="font-display font-bold text-evolea-purple text-lg">{lang === 'de' ? 'Kosten' : 'Cost'}</div>
            <div class="text-evolea-text-light">{lang === 'de' ? 'CHF 125 / Halbtag' : 'CHF 125 / half day'}</div>
          </div>
        </>
      )}
    </div>
  </div>
</section>

<!-- Main Content -->
<section class="py-16 md:py-24">
  <div class="container mx-auto max-w-4xl px-4">
    <div class="prose prose-lg max-w-none">

      <h2 class="text-3xl font-display font-bold text-evolea-purple mb-6 flex items-center gap-3">
        <span class="text-evolea-orange">●</span>
        {getText(fuerWen.titel, lang === 'de' ? 'Für wen ist Mini Projekte?' : 'Who is Mini Projekte for?')}
      </h2>
      <p class="text-evolea-text-light mb-8 text-lg leading-relaxed">
        {getText(fuerWen.text, lang === 'de' ? 'Mini Projekte richtet sich an Kinder im Autismus Spektrum im Alter von 5-8 Jahren. In unseren geschützten Social Skills Gruppen entwickeln Kinder soziale Kompetenzen durch gemeinsame Projekte – ausserhalb des Schulkontexts.' : 'Mini Projekte is aimed at children on the autism spectrum aged 5-8 years. In our protected social skills groups, children develop social skills through collaborative projects – outside of school.')}
      </p>

      <div class="bg-evolea-orange/10 border-l-4 border-evolea-orange rounded-r-evolea p-6 mb-12">
        <h3 class="font-display font-bold text-evolea-purple text-xl mb-2">{getText(fuerWen.voraussetzungenTitel, lang === 'de' ? 'Voraussetzungen für die Teilnahme' : 'Prerequisites for participation')}</h3>
        <ul class="text-evolea-text-light mb-0 space-y-2">
          {fuerWen.voraussetzungen?.length > 0 ? (
            fuerWen.voraussetzungen.map((v: any) => (
              <li>✓ {getText(v, '')}</li>
            ))
          ) : (
            <>
              <li>✓ {lang === 'de' ? 'Funktionelle Kommunikation' : 'Functional communication'}</li>
              <li>✓ {lang === 'de' ? 'Interesse an sozialem Kontakt' : 'Interest in social contact'}</li>
              <li>✓ {lang === 'de' ? 'Kann Anweisungen folgen' : 'Can follow instructions'}</li>
              <li>✓ {lang === 'de' ? 'Altersgerechte Selbstständigkeit' : 'Age-appropriate independence'}</li>
              <li>✓ {lang === 'de' ? 'Keine selbst- oder fremdverletzenden Verhaltensweisen' : 'No self-harming or aggressive behaviors'}</li>
            </>
          )}
        </ul>
      </div>

      <h2 class="text-3xl font-display font-bold text-evolea-purple mb-6 flex items-center gap-3">
        <span class="text-evolea-green">●</span>
        {getText(besonderheiten.titel, lang === 'de' ? 'Was macht Mini Projekte besonders?' : 'What makes Mini Projekte special?')}
      </h2>
      <div class="grid md:grid-cols-2 gap-6 mb-12">
        {besonderheiten.features?.length > 0 ? (
          besonderheiten.features.map((feature: any) => (
            <div class="bg-white border border-evolea-purple/10 rounded-evolea-lg p-6">
              <div class="flex justify-center mb-3"><Icon name={feature.icon || 'sparkle'} size="lg" /></div>
              <h3 class="font-display font-bold text-evolea-purple text-lg mb-2">{getText(feature.titel, '')}</h3>
              <p class="text-evolea-text-light mb-0">{getText(feature.text, '')}</p>
            </div>
          ))
        ) : (
          <>
            <div class="bg-white border border-evolea-purple/10 rounded-evolea-lg p-6">
              <div class="flex justify-center mb-3"><Icon name="target" size="lg" /></div>
              <h3 class="font-display font-bold text-evolea-purple text-lg mb-2">{lang === 'de' ? 'Sichtbare Erfolge' : 'Visible successes'}</h3>
              <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'Jedes Quartal schliesst mit einer Präsentation ab – Erfolge werden für alle sichtbar gemacht.' : 'Each quarter concludes with a presentation – successes are made visible to everyone.'}</p>
            </div>
            <div class="bg-white border border-evolea-purple/10 rounded-evolea-lg p-6">
              <div class="flex justify-center mb-3"><Icon name="family" size="lg" /></div>
              <h3 class="font-display font-bold text-evolea-purple text-lg mb-2">{lang === 'de' ? 'Entlastung für Eltern' : 'Relief for parents'}</h3>
              <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'Während die Kinder betreut werden, haben Eltern Zeit für sich oder können sich mit anderen Familien vernetzen.' : 'While the children are cared for, parents have time for themselves or can network with other families.'}</p>
            </div>
            <div class="bg-white border border-evolea-purple/10 rounded-evolea-lg p-6">
              <div class="flex justify-center mb-3"><Icon name="handshake" size="lg" /></div>
              <h3 class="font-display font-bold text-evolea-purple text-lg mb-2">{lang === 'de' ? 'Soziales Lernen' : 'Social learning'}</h3>
              <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'Teamarbeit, Kommunikation und Kooperation werden spielerisch in echten Projekten geübt.' : 'Teamwork, communication and cooperation are practiced playfully in real projects.'}</p>
            </div>
            <div class="bg-white border border-evolea-purple/10 rounded-evolea-lg p-6">
              <div class="flex justify-center mb-3"><Icon name="sparkle" size="lg" /></div>
              <h3 class="font-display font-bold text-evolea-purple text-lg mb-2">{lang === 'de' ? 'Abschlussfeier' : 'Closing celebration'}</h3>
              <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'Der letzte Halbtag jedes Quartals ist eine Feier – kostenlos von EVOLEA organisiert.' : 'The last half day of each quarter is a celebration – organized free of charge by EVOLEA.'}</p>
            </div>
          </>
        )}
      </div>

      <h2 class="text-3xl font-display font-bold text-evolea-purple mb-6 flex items-center gap-3" id="projekte">
        <span class="text-evolea-sky">●</span>
        {getText(projekte.titel, lang === 'de' ? 'Aktuelle & kommende Projekte' : 'Current & upcoming projects')}
      </h2>

      <div class="space-y-6 mb-12">
        {projekte.liste?.length > 0 ? (
          projekte.liste.map((projekt: any) => (
            projekt.link && projekt.link.length > 0 ? (
              <a href={translatePath(projekt.link)} class={`block bg-gradient-to-r ${fromColors[projekt.farbe] || 'from-evolea-orange/10'} to-transparent rounded-evolea-lg p-6 border-l-4 ${borderColors[projekt.farbe] || 'border-evolea-orange'} hover:shadow-card transition-all group`}>
                <div class="flex items-center justify-between mb-2">
                  <div class={`flex items-center gap-2 ${textColors[projekt.farbe] || 'text-evolea-orange'} font-medium text-sm`}>
                    <Icon name="heart" size="sm" /> {getText(projekt.zeitraum, '')}
                  </div>
                  <span class={`text-xs ${statusColors[projekt.statusFarbe] || 'bg-evolea-mint/20 text-evolea-green'} px-2 py-1 rounded-full`}>{getText(projekt.status, '')}</span>
                </div>
                <h3 class="font-display font-bold text-evolea-purple text-xl mb-2 group-hover:text-evolea-purple-light transition-colors">{projekt.titel}</h3>
                <p class="text-evolea-text-light mb-3">{getText(projekt.beschreibung, '')}</p>
                <span class={`${textColors[projekt.farbe] || 'text-evolea-orange'} font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all`}>
                  {lang === 'de' ? 'Mehr erfahren' : 'Learn more'}
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </a>
            ) : (
              <div class={`bg-gradient-to-r ${fromColors[projekt.farbe] || 'from-evolea-green/10'} to-transparent rounded-evolea-lg p-6 border-l-4 ${borderColors[projekt.farbe] || 'border-evolea-green'}`}>
                <div class="flex items-center justify-between mb-2">
                  <div class={`flex items-center gap-2 ${textColors[projekt.farbe] || 'text-evolea-green'} font-medium text-sm`}>
                    <Icon name="heart" size="sm" /> {getText(projekt.zeitraum, '')}
                  </div>
                  <span class={`text-xs ${statusColors[projekt.statusFarbe] || 'bg-evolea-mint/20 text-evolea-green'} px-2 py-1 rounded-full`}>{getText(projekt.status, '')}</span>
                </div>
                <h3 class="font-display font-bold text-evolea-purple text-xl mb-2">{projekt.titel}</h3>
                <p class="text-evolea-text-light mb-0">{getText(projekt.beschreibung, '')}</p>
              </div>
            )
          ))
        ) : (
          <>
            <a href={translatePath('/angebote/mini-projekte/mini-restaurant/')} class="block bg-gradient-to-r from-evolea-orange/10 to-transparent rounded-evolea-lg p-6 border-l-4 border-evolea-orange hover:shadow-card transition-all group">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2 text-evolea-orange font-medium text-sm">
                  <Icon name="heart" size="sm" /> {lang === 'de' ? 'Oktober - Dezember 2025' : 'October - December 2025'}
                </div>
                <span class="text-xs bg-evolea-magenta/20 text-evolea-magenta px-2 py-1 rounded-full">{lang === 'de' ? 'Ausgebucht' : 'Fully booked'}</span>
              </div>
              <h3 class="font-display font-bold text-evolea-purple text-xl mb-2 group-hover:text-evolea-purple-light transition-colors">Mini Restaurant</h3>
              <p class="text-evolea-text-light mb-3">{lang === 'de' ? 'Kochen, Servieren, Teamwork – die Kinder gestalten und betreiben ihr eigenes kleines Restaurant.' : 'Cooking, serving, teamwork – the children design and run their own little restaurant.'}</p>
              <span class="text-evolea-orange font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
                {lang === 'de' ? 'Mehr erfahren' : 'Learn more'}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </a>

            <a href={translatePath('/angebote/mini-museum/')} class="block bg-gradient-to-r from-evolea-purple/10 to-transparent rounded-evolea-lg p-6 border-l-4 border-evolea-purple hover:shadow-card transition-all group">
              <div class="flex items-center justify-between mb-2">
                <div class="flex items-center gap-2 text-evolea-purple font-medium text-sm">
                  <Icon name="palette" size="sm" /> {lang === 'de' ? 'Februar – April 2026' : 'February – April 2026'}
                </div>
                <span class="text-xs bg-evolea-mint/20 text-evolea-green px-2 py-1 rounded-full">{lang === 'de' ? 'Anmeldung offen' : 'Registration open'}</span>
              </div>
              <h3 class="font-display font-bold text-evolea-purple text-xl mb-2 group-hover:text-evolea-purple-light transition-colors">Mini Museum</h3>
              <p class="text-evolea-text-light mb-3">{lang === 'de' ? 'Kunst, Kreativität und Ausdruck – gemeinsam wird ein eigenes Museum gestaltet und eröffnet.' : 'Art, creativity and expression – together a museum of their own is designed and opened.'}</p>
              <span class="text-evolea-purple font-medium text-sm flex items-center gap-1 group-hover:gap-2 transition-all">
                {lang === 'de' ? 'Mehr erfahren' : 'Learn more'}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </span>
            </a>

            <div class="bg-gradient-to-r from-evolea-green/10 to-transparent rounded-evolea-lg p-6 border-l-4 border-evolea-green">
              <div class="flex items-center gap-2 text-evolea-green font-medium text-sm mb-2">
                <Icon name="leaf" size="sm" /> {lang === 'de' ? 'Juli 2026' : 'July 2026'}
              </div>
              <h3 class="font-display font-bold text-evolea-purple text-xl mb-2">Mini Abenteuercamp</h3>
              <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'Abenteuer, Sport und Natur – ein Sommerprojekt voller Bewegung und Entdeckungen.' : 'Adventure, sports and nature – a summer project full of movement and discoveries.'}</p>
            </div>
          </>
        )}
      </div>

      <h2 class="text-3xl font-display font-bold text-evolea-purple mb-6 flex items-center gap-3">
        <span class="text-evolea-coral">●</span>
        {getText(praktischeInfos.titel, lang === 'de' ? 'Praktische Informationen' : 'Practical Information')}
      </h2>

      <div class="bg-evolea-purple/5 rounded-evolea-lg p-8 mb-12">
        <div class="space-y-4">
          {praktischeInfos.infos?.length > 0 ? (
            praktischeInfos.infos.map((info: any) => (
              <div class="flex items-start gap-3">
                <Icon name={info.icon || 'calendar'} size="sm" />
                <div>
                  <strong class="text-evolea-purple">{getText(info.label, '')}</strong>
                  <p class="text-evolea-text-light mb-0">{getText(info.wert, '')}</p>
                </div>
              </div>
            ))
          ) : (
            <>
              <div class="flex items-start gap-3">
                <Icon name="calendar" size="sm" />
                <div>
                  <strong class="text-evolea-purple">{lang === 'de' ? 'Ablauf' : 'Schedule'}</strong>
                  <p class="text-evolea-text-light mb-0">{lang === 'de' ? '3-Monats-Quartale mit 6 Halbtagen (alle 2 Wochen samstags, ca. 3 Stunden)' : '3-month quarters with 6 half days (every 2 weeks on Saturdays, approx. 3 hours)'}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Icon name="people" size="sm" />
                <div>
                  <strong class="text-evolea-purple">{lang === 'de' ? 'Gruppengrösse' : 'Group size'}</strong>
                  <p class="text-evolea-text-light mb-0">{lang === 'de' ? '4-8 Kinder pro Gruppe' : '4-8 children per group'}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Icon name="location" size="sm" />
                <div>
                  <strong class="text-evolea-purple">{lang === 'de' ? 'Standort' : 'Location'}</strong>
                  <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'Stapferstrasse 10, 8006 Zürich (Nähe Seilbahn Rigiblick)' : 'Stapferstrasse 10, 8006 Zurich (near Rigiblick cable car)'}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Icon name="money" size="sm" />
                <div>
                  <strong class="text-evolea-purple">{lang === 'de' ? 'Kosten' : 'Cost'}</strong>
                  <p class="text-evolea-text-light mb-0">{lang === 'de' ? 'CHF 125 pro Halbtag (Abschlussfeier kostenlos)' : 'CHF 125 per half day (closing celebration free)'}</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <Icon name="mail" size="sm" />
                <div>
