---
import { getLangFromUrl, getLanguageAlternates } from '@i18n/utils';
import { getEntry } from 'astro:content';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import FooterDonationCTA from '@components/FooterDonationCTA.astro';
import FontFaces from '@components/FontFaces.astro';

import '../styles/global.css';

// __SSR_BUILD__ is injected by astro.config.mjs (Vite `define`): true only when
// the Cloudflare adapter is active (output: 'server'). False on static builds
// (GitHub Pages mirror, adapter-absent local) — used to emit a noindex meta on
// those builds so the de-indexed mirror never competes with production.
declare const __SSR_BUILD__: boolean;

interface Props {
  title: string;
  description?: string;
  image?: string;
  transparentHeader?: boolean;
  hideFooterCTA?: boolean;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'EVOLEA Verein - Bildungsangebote für Kinder im Autismus Spektrum oder mit ADHS in Zürich.',
  image = '/images/og-default.jpg',
  transparentHeader = false,
  hideFooterCTA = false,
  ogType = 'website',
} = Astro.props;

const siteSettingsEntry = await getEntry('settings', 'site');
const siteSettings = siteSettingsEntry?.data;

const lang = getLangFromUrl(Astro.url);
const alternates = getLanguageAlternates(Astro.url);
// Slash-normalized canonical: every page advertises exactly one URL form (the
// trailing-slash form the middleware 301s to), so og:url/twitter:url below can
// mirror it and Google never sees two canonical variants (SEO-03).
const canonicalPath = Astro.url.pathname.endsWith('/')
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;
const canonicalURL = new URL(canonicalPath, Astro.site);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
// OG/Twitter image must honor the configured base path (e.g. /evolea-website
// on GitHub Pages) — same base-URL invariant as fonts/favicons below.
const ogImage = new URL(`${base}${image}`, Astro.site);
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title} – EVOLEA</title>
    <meta name="title" content={`${title} – EVOLEA`} />
    <meta name="description" content={description} />

    {/* Static-build (GitHub Pages mirror / adapter-absent local) noindex —
        Cloudflare SSR pages never carry this. */}
    {!__SSR_BUILD__ && <meta name="robots" content="noindex, nofollow" />}

    <!-- Theme color for mobile browsers -->
    <meta name="theme-color" content="#6B4C8A" />

    <!-- Canonical & Language Alternates -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" type="application/xml" href={`${base}/sitemap-index.xml`} />
    {alternates.map(({ lang, href }) => (
      <link rel="alternate" hreflang={lang} href={new URL(href, Astro.site)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(alternates.find((a) => a.lang === 'de')?.href ?? '/', Astro.site)} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={`${title} – EVOLEA`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'de' ? 'de_CH' : 'en_US'} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={`${title} – EVOLEA`} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/apple-touch-icon.png`} />

    <!-- Self-hosted fonts (base-prefixed @font-face, dual-build-safe) -->
    <FontFaces />

    <!-- Preload critical above-the-fold font weights (base-prefixed for both build bases) -->
    <link rel="preload" href={`${base}/fonts/Fredoka-SemiBold.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/Poppins-Regular.woff2`} as="font" type="font/woff2" crossorigin />

    <!-- Hero video is preloaded by the video element itself -->
  </head>
  <body class="bg-evolea-cream text-evolea-text min-h-screen flex flex-col antialiased font-sans">
    <!-- Skip link for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[200] focus:bg-evolea-purple focus:text-white focus:px-6 focus:py-3 focus:rounded-full focus:shadow-lg focus:font-semibold"
    >
      {lang === 'de' ? 'Zum Hauptinhalt springen' : 'Skip to main content'}
    </a>

    <Header transparent={transparentHeader} siteSettings={siteSettings} />

    <main id="main-content" class:list={['flex-1', { 'pt-0': transparentHeader, 'pt-[72px]': !transparentHeader }]}>
      <slot />
    </main>

    {!hideFooterCTA && <FooterDonationCTA />}

    <Footer siteSettings={siteSettings} />

    <!-- GSAP Scroll Animations -->
    <script>
      import { initScrollAnimations } from '@/scripts/gsap-animations';

      // Initialize on DOM ready
      document.addEventListener('DOMContentLoaded', () => {
        initScrollAnimations();
      });

      // Re-initialize on Astro page transitions (if using View Transitions)
      document.addEventListener('astro:page-load', () => {
        initScrollAnimations();
      });
    </script>

    <!-- Legacy scroll reveal script (fallback for non-GSAP elements) -->
    <script>
      // Intersection Observer for scroll reveal animations
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -100px 0px',
        threshold: 0.1,
      };

      const revealOnScroll = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
            // Optional: unobserve after reveal for performance
            // revealOnScroll.unobserve(entry.target);
          }
        });
      }, observerOptions);

      // Observe all elements with reveal classes (not handled by GSAP)
      document.querySelectorAll('.reveal, .reveal-scale, .reveal-left, .reveal-right').forEach((el) => {
        revealOnScroll.observe(el);
      });
    </script>
  </body>
</html>
