{
  "name": "evolea-website",
  "type": "module",
  "version": "1.0.0",
  "description": "EVOLEA Verein - Bildungsangebote für Kinder im Spektrum",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "node scripts/gen-headers.mjs && astro check && astro build",
    "build:cloudflare": "npm install @astrojs/cloudflare@12.6.13 --no-save && node scripts/gen-headers.mjs && astro check && astro build",
    "gen:headers": "node scripts/gen-headers.mjs",
    "convert:images": "node scripts/convert-images.mjs",
    "convert:images:from-originals": "node scripts/convert-images.mjs --from-originals",
    "test:e2e": "npm run build:cloudflare && npm run test:e2e:served",
    "test:e2e:served": "playwright test",
    "preview": "astro preview",
    "astro": "astro",
    "prepare": "husky || true",
    "cf:clean-queue": "powershell -ExecutionPolicy Bypass -File scripts/Cancel-CloudflareDeployments.ps1 -OnlyInProgress",
    "cf:clean-all": "powershell -ExecutionPolicy Bypass -File scripts/Cancel-CloudflareDeployments.ps1"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/react": "^4.4.2",
    "@astrojs/sitemap": "^3.2.1",
    "@astrojs/tailwind": "^6.0.2",
    "@keystatic/astro": "^5.0.6",
    "@keystatic/core": "^0.5.48",
    "astro": "^5.1.1",
    "gsap": "^3.14.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.7.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "1.57.0",
    "husky": "^9.1.7",
    "playwright-core": "^1.57.0"
  }
}
